      "version": 1,
      "versionNonce": 396418890,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "From a trace -> click to see the logs for that exact request\nFrom a log line -> click the trace ID to see the full trace\nFrom a trace -> see the metrics for that service and route\n\nJump from 'what is slow?' (metrics) to 'where is the bottleneck?'\n(traces) to 'what is the error?' (logs) in seconds.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "From a trace -> click to see the logs for that exact request\nFrom a log line -> click the trace ID to see the full trace\nFrom a trace -> see the metrics for that service and route\n\nJump from 'what is slow?' (metrics) to 'where is the bottleneck?'\n(traces) to 'what is the error?' (logs) in seconds.",
      "autoResize": true,
      "lineHeight": 1.25
    },
