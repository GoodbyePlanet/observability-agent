    },
    {
      "id": "e00031",
      "type": "text",
      "x": 8960,
      "y": 210,
      "width": 406.1,
      "height": 247.5,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "e00026",
      "index": "a00031",
      "roundness": null,
      "seed": 735034882,
      "version": 1,
      "versionNonce": 1051454924,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Follow a single request across\nmultiple services. Each step is a span.\n\nExample: 'Place Order' trace:\n  order-service (200ms total)\n    GET catalog/products (30ms)\n    POST inventory/reserve (45ms)\n    INSERT orders table (15ms)\n\nAnswers: Where did the time go?\nWhich service is slow?",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Follow a single request across\nmultiple services. Each step is a span.\n\nExample: 'Place Order' trace:\n  order-service (200ms total)\n    GET catalog/products (30ms)\n    POST inventory/reserve (45ms)\n    INSERT orders table (15ms)\n\nAnswers: Where did the time go?\nWhich service is slow?",
      "autoResize": true,
      "lineHeight": 1.25
    },
