      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Open-source, vendor-neutral standard for collecting\nall three signals (traces, metrics, logs).\n\nKey idea: Instrument once, send to any backend\n\u2014 Grafana, Datadog, New Relic, Jaeger, etc.",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Open-source, vendor-neutral standard for collecting\nall three signals (traces, metrics, logs).\n\nKey idea: Instrument once, send to any backend\n\u2014 Grafana, Datadog, New Relic, Jaeger, etc.",
      "autoResize": true,
      "lineHeight": 1.25
    },
