      "seed": 154739679,
      "version": 1,
      "versionNonce": 1585770585,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "MCP (Model Context Protocol) is an open standard that\nlets AI models (like Claude or GPT) use external tools\nthrough a standardized interface.",
      "fontSize": 26,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "MCP (Model Context Protocol) is an open standard that\nlets AI models (like Claude or GPT) use external tools\nthrough a standardized interface.",
      "autoResize": true,
      "lineHeight": 1.25
    },
