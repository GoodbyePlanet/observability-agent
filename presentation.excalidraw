      "originalText": "Cons",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "e00087",
      "type": "text",
      "x": 16500,
      "y": 190,
      "width": 460.00000000000006,
      "height": 275.0,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "e00079",
      "index": "a00087",
      "roundness": null,
      "seed": 1748309235,
      "version": 1,
      "versionNonce": 817804384,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "  Startup overhead \u2014 a few extra seconds\n\n  Memory overhead \u2014 span/metric buffers\n\n  Limited control \u2014 auto-generated spans\n  may miss business-specific context\n\n  Version coupling \u2014 agent vs libraries\n\n  \"Magic\" \u2014 invisible bytecode changes\n  can be hard to debug",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "  Startup overhead \u2014 a few extra seconds\n\n  Memory overhead \u2014 span/metric buffers\n\n  Limited control \u2014 auto-generated spans\n  may miss business-specific context\n\n  Version coupling \u2014 agent vs libraries\n\n  \"Magic\" \u2014 invisible bytecode changes\n  can be hard to debug",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "e00088",
      "type": "text",
      "x": 15620,
      "y": 750,
      "width": 889.0000000000001,
      "height": 50.0,
      "angle": 0,
      "strokeColor": "#4a90d9",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "e00079",
      "index": "a00088",
      "roundness": null,
      "seed": 405126229,
      "version": 1,
      "versionNonce": 416314668,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "In our app we use custom annotations (@WithSpan) on top of auto-instrumentation\nfor business logic visibility.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In our app we use custom annotations (@WithSpan) on top of auto-instrumentation\nfor business logic visibility.",
      "autoResize": true,
      "lineHeight": 1.25
    },
