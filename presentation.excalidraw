      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Traces",
      "fontSize": 28,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "e00029",
      "originalText": "Traces",
      "autoResize": true,
