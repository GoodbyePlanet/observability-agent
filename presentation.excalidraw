    {
      "id": "e00034",
      "type": "text",
      "x": 9560,
      "y": 210,
      "width": 346.70000000000005,
      "height": 202.5,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "e00026",
      "index": "a00034",
      "roundness": null,
      "seed": 943239975,
      "version": 1,
      "versionNonce": 1392783744,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Numerical measurements over time.\n\n  HTTP request rate: 150 req/s\n  P95 latency: 230ms\n  Error rate: 2.3%\n  JVM memory usage: 256MB\n\nAnswers: Is the system healthy?\nAre things getting worse?",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Numerical measurements over time.\n\n  HTTP request rate: 150 req/s\n  P95 latency: 230ms\n  Error rate: 2.3%\n  JVM memory usage: 256MB\n\nAnswers: Is the system healthy?\nAre things getting worse?",
      "autoResize": true,
      "lineHeight": 1.25
    },
