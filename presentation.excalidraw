      "version": 1,
      "versionNonce": 1443665391,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Tools Available:\n\n  traceql-search              Execute TraceQL queries\n  get-trace                   Fetch a trace by ID\n  get-attribute-names         Discover trace attributes\n  get-attribute-values        List values for an attribute\n  docs-traceql                Get TraceQL syntax docs\n  traceql-metrics-instant     Compute instant metrics\n  traceql-metrics-range       Compute range metrics",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tools Available:\n\n  traceql-search              Execute TraceQL queries\n  get-trace                   Fetch a trace by ID\n  get-attribute-names         Discover trace attributes\n  get-attribute-values        List values for an attribute\n  docs-traceql                Get TraceQL syntax docs\n  traceql-metrics-instant     Compute instant metrics\n  traceql-metrics-range       Compute range metrics",
