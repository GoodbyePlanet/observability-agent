    },
    {
      "id": "e00155",
      "type": "text",
      "x": 26720,
      "y": 430,
      "width": 719.6,
      "height": 150.0,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "e00149",
      "index": "a00155",
      "roundness": null,
      "seed": 1323959528,
      "version": 1,
      "versionNonce": 1566166315,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "A universal plug that connects any AI model to any\ndata source or tool.\n\nBefore MCP: every AI integration was custom.\nWith MCP: build a tool once, any AI model can use it.",
      "fontSize": 24,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A universal plug that connects any AI model to any\ndata source or tool.\n\nBefore MCP: every AI integration was custom.\nWith MCP: build a tool once, any AI model can use it.",
      "autoResize": true,
      "lineHeight": 1.25
    },
