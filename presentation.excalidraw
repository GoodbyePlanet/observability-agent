    {
      "id": "e00144",
      "type": "text",
      "x": 22280,
      "y": 700,
      "width": 735.0000000000001,
      "height": 150.0,
      "angle": 0,
      "strokeColor": "#343a40",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
