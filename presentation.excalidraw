      "boundElements": null,
      "updated": 1713700000000,
      "link": null,
      "locked": false,
      "text": "Timestamped text messages.\n\n  INFO  order-service:\n    Order created for product 42\n  ERROR inventory-service:\n    Insufficient stock for 42\n\nAnswers: What exactly happened?\nWhat was the error message?",
      "fontSize": 18,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Timestamped text messages.\n\n  INFO  order-service:\n    Order created for product 42\n  ERROR inventory-service:\n    Insufficient stock for 42\n\nAnswers: What exactly happened?\nWhat was the error message?",
      "autoResize": true,
      "lineHeight": 1.25
    },
